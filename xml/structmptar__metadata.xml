        <argsstring></argsstring>
        <name>typeflag</name>
        <qualifiedname>mptar_metadata::typeflag</qualifiedname>
        <briefdescription>
<para>File entry type flag. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="note"><para>Standard values include:<itemizedlist>
<listitem><para><computeroutput>&apos;0&apos;</computeroutput> or <computeroutput>&apos;\0&apos;</computeroutput>: Regular file</para>
</listitem><listitem><para><computeroutput>&apos;1&apos;</computeroutput>: Hard link</para>
</listitem><listitem><para><computeroutput>&apos;2&apos;</computeroutput>: Symbolic link</para>
</listitem><listitem><para><computeroutput>&apos;3&apos;</computeroutput>: Character special file</para>
</listitem><listitem><para><computeroutput>&apos;4&apos;</computeroutput>: Block special file</para>
</listitem><listitem><para><computeroutput>&apos;5&apos;</computeroutput>: Directory</para>
</listitem><listitem><para><computeroutput>&apos;6&apos;</computeroutput>: FIFO / pipe</para>
</listitem><listitem><para><computeroutput>&apos;7&apos;</computeroutput>: Contiguous file</para>
</listitem><listitem><para><computeroutput>&apos;x&apos;</computeroutput>: PAX extended header</para>
</listitem><listitem><para><computeroutput>&apos;g&apos;</computeroutput>: PAX global extended header </para>
</listitem></itemizedlist>
</para>
</simplesect>
</para>
        </detaileddescription>
