        <definition>mptar_uint32 mptar_timespec::nsec</definition>
        <argsstring></argsstring>
        <name>nsec</name>
        <qualifiedname>mptar_timespec::nsec</qualifiedname>
        <briefdescription>
<para>Sub-second precision in nanoseconds. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="note"><para>Must not exceed 999,999,999 when writing, or an error will occur. Attempting to write an invalid nanosecond value triggers a specific error: <ref refid="group__mptar__error__codes_1gadf41e0d6c299f94b8380e32ac9d6e75c" kindref="member">MPTAR_ERR_NS_CONVERSION_FAILED</ref>. </para>
</simplesect>
</para>
        </detaileddescription>
