PROJECT_NAME           = "minipaxtar"
INPUT                  = minipaxtar.h minipaxtar.c
OPTIMIZE_OUTPUT_FOR_C  = YES

# Force extract all symbols into XML
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
SEARCH_INCLUDES        = YES
JAVADOC_AUTOBRIEF      = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

# Enable XML Output
GENERATE_XML           = YES
XML_OUTPUT             = docs/xml
GENERATE_HTML          = NO
GENERATE_LATEX         = NO

# Warnings
WARNINGS = YES
WARN_IF_DOC_ERROR = YES
WARN_IF_UNDOCUMENTED = YES
WARN_NO_PARAMDOC = YES
WARN_LOGFILE = doxygen_warnings.log